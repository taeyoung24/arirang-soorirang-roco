# Copy this file to .env and replace the values before running docker compose.
POSTGRES_DB=arirang
POSTGRES_USER=replace_me
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgresql+psycopg://replace_me:replace_me@localhost:5433/arirang
VITE_API_BASE_URL=
MDD_API_HOST_PORT=18080
MDD_MINIO_HOST_PORT=19000
MDD_MINIO_CONSOLE_HOST_PORT=19001
BACKEND_TTS_GENERATION_ENABLED=true
BACKEND_TTS_GENERATION_REQUIRED=false
BACKEND_TTS_GENERATION_RETRIES=5
BACKEND_TTS_GENERATION_RETRY_SECONDS=2
BACKEND_PRONUNCIATION_ANALYSIS_ENDPOINT=/analyze-pronunciation-llm
BACKEND_PRONUNCIATION_ANALYSIS_TIMEOUT_SECONDS=180
MDD_OBJECT_STORAGE_ACCESS_KEY=mddadmin
MDD_OBJECT_STORAGE_SECRET_KEY=mddadmin123
MDD_OBJECT_STORAGE_BUCKET=mdd-reference-cache
MDD_TTS_PROVIDER=edge
MDD_TTS_MODEL=edge-tts
MDD_TTS_VOICE_ID=ko-KR-SunHiNeural
MDD_TTS_SPEAKING_RATE=1.0
MDD_TTS_ASSET_PUBLIC_BASE_URL=/ml
