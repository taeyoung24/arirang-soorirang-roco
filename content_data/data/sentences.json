  },
  {
    "id": "cb6d46b0",
    "meaning_id": "03c7ae56",
    "content": "학사모를 높이 써보자.",
    "highlight": "써보자"
  },
  {
    "id": "1cca1566",
    "meaning_id": "03c7ae56",
    "content": "군밤 모자를 써봐.",
    "highlight": "써봐"
  },
  {
    "id": "3c573d31",
    "meaning_id": "03c7ae56",
    "content": "공사장에선 안전모를 꼭 써라.",
    "highlight": "써라."
  },
  {
    "id": "c7390267",
    "meaning_id": "03c7ae56",
    "content": "수술용 모자를 바르게 쓰세요.",
    "highlight": "쓰세요."
  },
  {
    "id": "0f85cffe",
    "meaning_id": "03c7ae56",
    "content": "편의점 갈 때 이 모자 써봐.",
    "highlight": "써봐."
  },
  {
    "id": "89d054da",
    "meaning_id": "03c7ae56",
    "content": "초등학교 등굣길엔 모자를 씁시다.",
    "highlight": "씁시다."
  },
  {
    "id": "d4bf11d9",
    "meaning_id": "03c7ae56",
    "content": "교복 입고 학년 모자 높이 써.",
    "highlight": "써."
  },
  {
    "id": "1ef24963",
    "meaning_id": "03c7ae56",
    "content": "등굣길엔 노란 모자를 써요.",
    "highlight": "써요"
  },
  {
    "id": "a3b98ce9",
    "meaning_id": "03c7ae56",
    "content": "학사모를 쓰고 추억을 남겨.",
    "highlight": "쓰고"
  },
  {
    "id": "fa623d79",
    "meaning_id": "03c7ae56",
    "content": "공사장에선 안전모를 씁시다.",
    "highlight": "씁시다"
  },
  {
    "id": "dcfb3c33",
    "meaning_id": "03c7ae56",
    "content": "학년이 바뀌면 새 모자를 써.",
    "highlight": "써"
  },
  {
    "id": "c96022f7",
    "meaning_id": "03c7ae56",
    "content": "편의점 갈 때도 모자를 쓴다.",
    "highlight": "쓴다"
  },
  {
    "id": "20e16be2",
    "meaning_id": "03c7ae56",
    "content": "학사모를 바르게 씁시다?",
    "highlight": "씁시다"
  },
  {
    "id": "39e68c6e",
    "meaning_id": "03c7ae56",
    "content": "교복에 모자를 쓸까요?",
    "highlight": "쓸까요"
  },
  {
    "id": "d429ba0b",
    "meaning_id": "03c7ae56",
    "content": "등굣길엔 모자를 써요?",
    "highlight": "써요"
  },
  {
    "id": "fc730b73",
    "meaning_id": "03c7ae56",
    "content": "군밤 모자 쓴 아이예요?",
    "highlight": "쓴"
  },
  {
    "id": "53b17d48",
    "meaning_id": "03c7ae56",
    "content": "환자가 모자를 썼나요?",
    "highlight": "썼나요"
  },
  {
    "id": "3bc39e12",
    "meaning_id": "8dfa7526",
    "content": "알림장에 숙제를 써.",
    "highlight": "써"
  },
  {
    "id": "eb2a3cd0",
    "meaning_id": "8dfa7526",
    "content": "처방전을 써 줄게.",
    "highlight": "써"
  },
  {
    "id": "69533845",
    "meaning_id": "8dfa7526",
    "content": "편의점에서 명부 써.",
    "highlight": "써"
  },
  {
    "id": "ead1ef20",
    "meaning_id": "8dfa7526",
    "content": "칠판에 답을 써 봐.",
    "highlight": "써"
  },
  {
    "id": "4143025d",
    "meaning_id": "8dfa7526",
    "content": "연습장에 이름을 써.",
    "highlight": "써"
  },
  {
    "id": "e039f251",
    "meaning_id": "8dfa7526",
    "content": "연습장에 답을 써 봐.",
    "highlight": "써"
  },
  {
    "id": "e9c4d0e9",
    "meaning_id": "8dfa7526",
    "content": "칠판에 이름을 쓰세요.",
    "highlight": "쓰세요"
  },
  {
    "id": "e5676ab4",
    "meaning_id": "8dfa7526",
    "content": "알림장에 숙제를 써라.",
    "highlight": "써라"
  },
  {
    "id": "ffaa9a11",
    "meaning_id": "8dfa7526",
    "content": "처방전을 써 주십시오.",
    "highlight": "써"
  },
  {
    "id": "ebf58e7f",
    "meaning_id": "8dfa7526",
    "content": "편의점 명부를 쓰자.",
